# ─── Telegram Bot ───
BOT_TOKEN=your_telegram_bot_token_from_botfather

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sitotabot

# ─── Optional: Random.org API ───
RANDOM_ORG_API_KEY=

# ─── Webhook Mode (optional, defaults to long-polling) ───
# Set WEBHOOK_URL to enable webhook mode instead of long-polling
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=

# ─── Logging ───
LOG_LEVEL=info

# ─── Bot Settings ───
# Default minimum account age in days for giveaway eligibility
DEFAULT_MIN_ACCOUNT_AGE=0
# Maximum participants per giveaway (0 = unlimited)
MAX_PARTICIPANTS=0
