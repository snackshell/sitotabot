{
  "name": "sitotabot",
  "version": "1.0.0",
  "description": "Telegram Growth Giveaway Bot — fair, verifiable, scalable giveaways for Telegram channels",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "telegram",
    "bot",
    "giveaway",
    "grammy",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "grammy": "^1.30.0",
    "@grammyjs/conversations": "^2.0.2",
    "@grammyjs/hydrate": "^1.4.1",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5",
    "dotenv": "^16.4.7",
    "zod": "^3.24.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "node-cron": "^3.0.3",
    "csv-stringify": "^6.5.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.29.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "vitest": "^2.1.0"
  }
}
